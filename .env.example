# ─────────────────────────────────────────
# BoxCostPro — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# ── PostgreSQL ──────────────────────────
POSTGRES_DB=boxcostpro
POSTGRES_USER=boxcostpro
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ───────────────────────────────
REDIS_URL=redis://:change_me_redis_password@redis:6379/0
REDIS_PASSWORD=change_me_redis_password

# ── Object Storage (MinIO / S3-compatible) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio_password
S3_BUCKET_NAME=boxcostpro
# For AWS S3, set S3_ENDPOINT_URL to empty string and provide real keys.

# ── Security ────────────────────────────
# 32-byte hex string for AES-256-GCM encryption (SMTP passwords, OAuth tokens)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change_me_32_byte_hex_key_here_000000000000000000000000000000

# Cookie signing secret (at least 32 random characters)
SESSION_SECRET=change_me_session_secret_here

# Platform admin API key (for /api/v1/admin/* endpoints)
ADMIN_API_KEY=change_me_platform_admin_key_here

# ── App Config ──────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SESSION_TTL_DAYS=7

# ── Email (SendGrid fallback for invitations when tenant SMTP not configured) ──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@boxcostpro.com
SENDGRID_FROM_NAME=BoxCostPro

# ── Frontend (build-time vars — prefix with VITE_) ──
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=BoxCostPro
